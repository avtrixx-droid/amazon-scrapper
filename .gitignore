# Python virtual environments — recreated automatically
.venv/
.venv_build/

# Generated at runtime — never commit these
progress/
logs/
output/
.scraper.lock

# PyInstaller build output — rebuild from spec files, not versioned
build/
dist/

# macOS system files
.DS_Store
__pycache__/
*.pyc
*.pyo

# IDE files
.idea/

# Excel reports (share via email or Drive)
*.xlsx

# Secrets / personal config overrides
config.local.py
.env
